{
  "id": "com.dustin.zemismart-blind",
  "version": "1.1.0",
  "source": "https://github.com/dhannifin/homey-zemismart-blind",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "brandColor": "#4a90d9",
  "name": {
    "en": "Zemismart Zigbee Blind"
  },
  "description": {
    "en": "Driver for Zemismart and Tuya Zigbee blind/shutter motors (TS0601 based)"
  },
  "author": {
    "name": "Dustin Hannifin",
    "email": "dustin@hannifin.us"
  },
  "category": [
    "appliances"
  ],
  "permissions": [],
  "drivers": [
    {
      "id": "zemismart-blind",
      "name": {
        "en": "Zemismart Blind Motor"
      },
      "class": "windowcoverings",
      "capabilities": [
        "windowcoverings_state",
        "windowcoverings_set"
      ],
      "zigbee": {
        "manufacturerName": ["_TZE200_cxu0jkjk"],
        "productId": ["TS0601"],
        "endpoints": {
          "1": {
            "clusters": [0, 4, 5, 6, 61184],
            "bindings": []
          }
        },
        "learnmode": {
          "instruction": {
            "en": "Press and hold the reset button on the motor controller for 5 seconds until the LED flashes, then release."
          }
        }
      },
      "settings": [
        {
          "id": "direction",
          "type": "dropdown",
          "label": {
            "en": "Motor Direction"
          },
          "value": "forward",
          "values": [
            {
              "id": "forward",
              "label": {
                "en": "Forward"
              }
            },
            {
              "id": "reverse",
              "label": {
                "en": "Reverse"
              }
            }
          ]
        },
        {
          "id": "invertPosition",
          "type": "checkbox",
          "label": {
            "en": "Invert Position"
          },
          "hint": {
            "en": "Some devices report position inverted (0=open, 100=closed). Enable this to correct."
          },
          "value": false
        }
      ]
    },
    {
      "id": "zemismart-shutter",
      "name": {
        "en": "Zemismart Shutter Motor"
      },
      "class": "windowcoverings",
      "capabilities": [
        "windowcoverings_state",
        "windowcoverings_set"
      ],
      "zigbee": {
        "manufacturerName": ["_TZE284_myikb7qz"],
        "productId": ["TS0601"],
        "endpoints": {
          "1": {
            "clusters": [0, 4, 5, 61184, 60672],
            "bindings": []
          }
        },
        "learnmode": {
          "instruction": {
            "en": "Press and hold the reset button on the shutter motor for 5 seconds until the LED flashes, then release."
          }
        }
      },
      "settings": [
        {
          "id": "direction",
          "type": "dropdown",
          "label": {
            "en": "Motor Direction"
          },
          "value": "forward",
          "values": [
            {
              "id": "forward",
              "label": {
                "en": "Forward"
              }
            },
            {
              "id": "reverse",
              "label": {
                "en": "Reverse"
              }
            }
          ]
        },
        {
          "id": "invertPosition",
          "type": "checkbox",
          "label": {
            "en": "Invert Position"
          },
          "hint": {
            "en": "Some devices report position inverted (0=open, 100=closed). Enable this to correct."
          },
          "value": false
        }
      ]
    }
  ]
}
